EXPO_PUBLIC_API_HOST=localhost
EXPO_PUBLIC_API_PORT=8080
EXPO_PUBLIC_API_PREFIX=/api
# Public origin serving post/profile media (S3/MinIO). Used for a <link rel="preconnect">
# in src/app/+html.tsx so the browser warms the media connection during first paint.
EXPO_PUBLIC_MEDIA_ORIGIN=http://localhost:9000