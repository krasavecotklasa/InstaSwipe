# Copy to .env and fill in values:  cp .env.example .env
# .env is gitignored — never commit real secrets. This file is a template only.

# --- MinIO (S3-compatible object storage) [required] ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- MongoDB [required] ---
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# --- Auth [required] ---
# JWT signing secret. MUST be a random 32+ byte value or the backend won't start.
# Generate one with:  openssl rand -base64 48
APP_JWT_SECRET=

# --- RabbitMQ [optional; docker-compose defaults to guest/guest] ---
RABBITMQ_ROOT_USERNAME=
RABBITMQ_ROOT_PASSWORD=

# --- Firebase Cloud Messaging [optional] ---
# Enables push notifications. Place your service-account JSON at ./secrets/service-account.json
# (bind-mounted read-only into the backend at the path below). Leave blank to disable FCM.
FIREBASE_CREDENTIALS=/etc/firebase/service-account.json

# --- GIF search [optional] ---
# Backend proxy keys for chat GIF search. Leave either blank to hide that provider's results.
GIPHY_API_KEY=
KLIPY_API_KEY=

# --- S3 public access [optional; docker-compose has sensible defaults] ---
# S3_PUBLIC_ENDPOINT=http://host.docker.internal:9000
# S3_PUBLIC_BUCKET=true
